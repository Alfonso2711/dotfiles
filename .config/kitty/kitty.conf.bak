background_opacity 0.85
dynamic_background_opacity yes
# font_family JetBrainsMono Nerd Font
shell zsh


# BEGIN_KITTY_FONTS
font_family      JetBrainsMono Nerd Font
bold_font        auto
italic_font      auto
bold_italic_font auto
font_size        12.0
# END_KITTY_FONTS


# BEGIN_KITTY_THEME
# Aquarium Dark
include current-theme.conf
# END_KITTY_THEME


